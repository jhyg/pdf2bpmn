# ===================================
# PDF2BPMN 에이전트 서버 환경 설정
# ===================================
# 
# 사용법:
# 1. 이 파일을 'agent.env'로 복사: copy agent.env.example agent.env
# 2. 아래 값들을 실제 값으로 변경
# 3. 에이전트 실행: python pdf2bpmn_agent_server.py
#
# 주의: PDF2BPMN API 서버(.env)와 별도의 파일입니다!
# ===================================

# Supabase 설정 (ProcessGPT와 동일한 값 사용)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SERVICE_ROLE_KEY=your-service-role-key-here

# LLM 프록시(OpenAI 호환) 설정
LLM_MODEL=openai/gpt-oss-120b
LLM_PROXY_URL=http://ai-server.dream-flow.com:30000/v1
LLM_PROXY_API_KEY=dream-flow

# 에이전트 설정
AGENT_ORCH=pdf2bpmn
POLLING_INTERVAL=5
TASK_TIMEOUT=3600


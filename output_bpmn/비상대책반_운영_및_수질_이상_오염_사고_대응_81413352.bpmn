    <bpmn:userTask id="Activity_bc70edf8" name="사고 접수 및 상황보고">
      <bpmn:extensionElements>
        <uengine:properties>
          <uengine:json>{"role": "환경4급", "duration": 5, "instruction": "사고 접수대장 작성 및 관리, 초동 및 위기대응 상황보고, KRM 자료작성 및 등록", "description": "사고 접수대장 작성 및 관리, 초동 및 위기대응 상황보고, KRM 자료작성 및 등록", "checkpoints": [], "agent": null, "agentMode": "none", "orchestration": null, "attachments": [], "inputData": [], "tool": "formHandler:defaultform", "customProperties": []}</uengine:json>
        </uengine:properties>
      </bpmn:extensionElements>
      
      <bpmn:incoming>SequenceFlow_Activity_a53dc3f2_Activity_bc70edf8</bpmn:incoming>
      
      
      <bpmn:outgoing>SequenceFlow_Activity_bc70edf8_Activity_d69a94cf</bpmn:outgoing>
      
    </bpmn:userTask>
    
    <bpmn:userTask id="Activity_d69a94cf" name="복구계획 및 수처리공정 대응방안 검토">
      <bpmn:extensionElements>
        <uengine:properties>
          <uengine:json>{"role": "실무직", "duration": 5, "instruction": "복구계획 및 수처리공정 대응방안 검토, 비상대책반 편성 완료 보고", "description": "복구계획 및 수처리공정 대응방안 검토, 비상대책반 편성 완료 보고", "checkpoints": [], "agent": null, "agentMode": "none", "orchestration": null, "attachments": [], "inputData": [], "tool": "formHandler:defaultform", "customProperties": []}</uengine:json>
        </uengine:properties>
      </bpmn:extensionElements>
      
      <bpmn:incoming>SequenceFlow_Activity_bc70edf8_Activity_d69a94cf</bpmn:incoming>
      
      
      <bpmn:outgoing>SequenceFlow_Activity_d69a94cf_Activity_10a1ed74</bpmn:outgoing>
      
    </bpmn:userTask>
    
    <bpmn:userTask id="Activity_10a1ed74" name="현장상황 전파 및 보고">
      <bpmn:extensionElements>
        <uengine:properties>
          <uengine:json>{"role": "전통3급", "duration": 5, "instruction": "대응현황, 주요상황 발생시 수시 상황전파, 추진경위 정리 및 현장상황 보고, 모바일 메신저 채팅방 구성", "description": "대응현황, 주요상황 발생시 수시 상황전파, 추진경위 정리 및 현장상황 보고, 모바일 메신저 채팅방 구성", "checkpoints": [], "agent": null, "agentMode": "none", "orchestration": null, "attachments": [], "inputData": [], "tool": "formHandler:defaultform", "customProperties": []}</uengine:json>
        </uengine:properties>

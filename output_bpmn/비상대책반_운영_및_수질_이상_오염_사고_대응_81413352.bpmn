    <bpmn:userTask id="Activity_a53dc3f2" name="비상대책반 편성">
      <bpmn:extensionElements>
        <uengine:properties>
          <uengine:json>{"role": "Control Tower", "duration": 5, "instruction": "수질 이상·오염 사고 발생 시 비상대책반을 편성", "description": "수질 이상·오염 사고 발생 시 비상대책반을 편성", "checkpoints": [], "agent": null, "agentMode": "none", "orchestration": null, "attachments": [], "inputData": [], "tool": "formHandler:defaultform", "customProperties": []}</uengine:json>

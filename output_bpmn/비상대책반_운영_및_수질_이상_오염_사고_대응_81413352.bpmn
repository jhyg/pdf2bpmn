      <bpmn:extensionElements>
        <uengine:properties>
          <uengine:json>{"role": "현장 담당자", "duration": 5, "instruction": "오염물질 확산 방지 대책(오엘펜스 설치, 유흡착포 살포, 차단 막 설치, 흙 제방 설치 등) 시행", "description": "오염물질 확산 방지 대책(오엘펜스 설치, 유흡착포 살포, 차단 막 설치, 흙 제방 설치 등) 시행", "checkpoints": [], "agent": null, "agentMode": "none", "orchestration": null, "attachments": [], "inputData": [], "tool": "formHandler:defaultform", "customProperties": []}</uengine:json>

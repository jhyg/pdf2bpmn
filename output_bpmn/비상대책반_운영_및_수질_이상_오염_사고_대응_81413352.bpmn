    <bpmn:userTask id="Activity_c57fec58" name="수질 이상·오염 사고 현장 확인">
      <bpmn:extensionElements>
        <uengine:properties>
          <uengine:json>{"role": "현장 담당자", "duration": 5, "instruction": "현장 육안 확인(오염물질 확산 정도 및 징후) 및 어류관찰수조 확인", "description": "현장 육안 확인(오염물질 확산 정도 및 징후) 및 어류관찰수조 확인", "checkpoints": [], "agent": null, "agentMode": "none", "orchestration": null, "attachments": [], "inputData": [], "tool": "formHandler:defaultform", "customProperties": []}</uengine:json>
        </uengine:properties>

      <bpmn:extensionElements>
        <uengine:properties>
          <uengine:json>{"role": "수질 담당자", "duration": 5, "instruction": "수질오염 모니터링 실시, 국가수질측망, 어류사육수조 관찰 결과 등 가용한 수질분석결과 활용", "description": "수질오염 모니터링 실시, 국가수질측망, 어류사육수조 관찰 결과 등 가용한 수질분석결과 활용", "checkpoints": [], "agent": null, "agentMode": "none", "orchestration": null, "attachments": [], "inputData": [], "tool": "formHandler:defaultform", "customProperties": []}</uengine:json>

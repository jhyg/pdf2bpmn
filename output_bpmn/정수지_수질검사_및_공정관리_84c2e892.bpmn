      <bpmn:extensionElements>
        <uengine:properties>
          <uengine:json>{"role": "수질 담당자", "duration": 5, "instruction": "정수지의 탁도, pH, 알칼리도, 잔류염소 등 수질 항목을 측정", "description": "정수지의 탁도, pH, 알칼리도, 잔류염소 등 수질 항목을 측정", "checkpoints": [], "agent": null, "agentMode": "none", "orchestration": null, "attachments": [], "inputData": [], "tool": "formHandler:defaultform", "customProperties": []}</uengine:json>

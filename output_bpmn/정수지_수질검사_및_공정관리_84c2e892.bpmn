      <bpmn:extensionElements>
        <uengine:properties>
          <uengine:json>{"role": "수질 담당자", "duration": 5, "instruction": "수질 항목 측정 결과에 따라 알칼리제 투입 및 후염소 투입률을 조정", "description": "수질 항목 측정 결과에 따라 알칼리제 투입 및 후염소 투입률을 조정", "checkpoints": [], "agent": null, "agentMode": "none", "orchestration": null, "attachments": [], "inputData": [], "tool": "formHandler:defaultform", "customProperties": []}</uengine:json>
        </uengine:properties>

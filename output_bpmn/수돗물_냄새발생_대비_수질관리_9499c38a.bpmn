      <bpmn:extensionElements>
        <uengine:properties>
          <uengine:json>{"role": "수질 담당자", "duration": 5, "instruction": "원수의 조류종, 조류개체수, 냄새를 주 1회(필요시 일 1회) 조사한다.", "description": "원수의 조류종, 조류개체수, 냄새를 주 1회(필요시 일 1회) 조사한다.", "checkpoints": [], "agent": null, "agentMode": "none", "orchestration": null, "attachments": [], "inputData": [], "tool": "formHandler:defaultform", "customProperties": []}</uengine:json>

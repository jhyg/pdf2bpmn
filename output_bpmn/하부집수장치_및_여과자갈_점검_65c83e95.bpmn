      <bpmn:extensionElements>
        <uengine:properties>
          <uengine:json>{"role": "수질 담당자", "duration": 5, "instruction": "자갈층 및 하부집수장치의 여과, 세척기능 점검 및 이상유무 검사", "description": "자갈층 및 하부집수장치의 여과, 세척기능 점검 및 이상유무 검사", "checkpoints": [], "agent": null, "agentMode": "none", "orchestration": null, "attachments": [], "inputData": [], "tool": "formHandler:defaultform", "customProperties": []}</uengine:json>

    <!-- Tasks -->
    
    <bpmn:userTask id="Activity_ca841b97" name="여재 시료 채취">
      <bpmn:extensionElements>
        <uengine:properties>
          <uengine:json>{"role": "시험자", "duration": 5, "instruction": "여재 단면별로 20cm 간격으로 코아채취관을 이용해 7개 구간 시료 채취", "description": "여재 단면별로 20cm 간격으로 코아채취관을 이용해 7개 구간 시료 채취", "checkpoints": [], "agent": null, "agentMode": "none", "orchestration": null, "attachments": [], "inputData": [], "tool": "formHandler:defaultform", "customProperties": []}</uengine:json>
        </uengine:properties>
      </bpmn:extensionElements>
      
      <bpmn:incoming>SequenceFlow_Event_Start_Activity_ca841b97</bpmn:incoming>
      
      
      <bpmn:outgoing>SequenceFlow_Activity_ca841b97_Activity_a6869fd0</bpmn:outgoing>
      
    </bpmn:userTask>
    
    <bpmn:userTask id="Activity_a6869fd0" name="여재 시료 교반 및 상징수 탁도 측정">
      <bpmn:extensionElements>
        <uengine:properties>
          <uengine:json>{"role": "시험자", "duration": 5, "instruction": "채취한 시료를 증류수에 담가 Jar-Tester에서 200rpm으로 30분간 교반 후 상징수의 탁도를 측정", "description": "채취한 시료를 증류수에 담가 Jar-Tester에서 200rpm으로 30분간 교반 후 상징수의 탁도를 측정", "checkpoints": [], "agent": null, "agentMode": "none", "orchestration": null, "attachments": [], "inputData": [], "tool": "formHandler:defaultform", "customProperties": []}</uengine:json>
        </uengine:properties>
      </bpmn:extensionElements>
      
      <bpmn:incoming>SequenceFlow_Activity_ca841b97_Activity_a6869fd0</bpmn:incoming>
      
      
      <bpmn:outgoing>SequenceFlow_Activity_a6869fd0_Activity_779fb927</bpmn:outgoing>
      
    </bpmn:userTask>
    
    <bpmn:userTask id="Activity_779fb927" name="역세척 전후 반복 시험 및 결과 그래프 도시">
      <bpmn:extensionElements>
        <uengine:properties>
          <uengine:json>{"role": "시험자", "duration": 5, "instruction": "동일한 시험을 역세척 전후에 1회씩 실시하고 결과를 그래프로 도시", "description": "동일한 시험을 역세척 전후에 1회씩 실시하고 결과를 그래프로 도시", "checkpoints": [], "agent": null, "agentMode": "none", "orchestration": null, "attachments": [], "inputData": [], "tool": "formHandler:defaultform", "customProperties": []}</uengine:json>
        </uengine:properties>
      </bpmn:extensionElements>
      
      <bpmn:incoming>SequenceFlow_Activity_a6869fd0_Activity_779fb927</bpmn:incoming>
      
      
      <bpmn:outgoing>SequenceFlow_Activity_779fb927_Event_End</bpmn:outgoing>
      
    </bpmn:userTask>
    

